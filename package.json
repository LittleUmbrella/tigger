{
  "name": "tigger",
  "version": "1.0.0",
  "description": "Crypto trading bot with Telegram signal harvesting",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/lib/ctrader/protobuf dist/lib/ctrader/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "docker:up": "docker compose up --build",
    "docker:build": "docker compose build",
    "evaluate": "tsx src/evaluation/index.ts",
    "evaluate:build": "npm run build && node dist/evaluation/index.js",
    "export-messages": "tsx src/scripts/export_messages.ts",
    "generate-session": "tsx src/scripts/generate_session.ts",
    "ctrader-auth": "tsx src/ctrader-server.ts",
    "test-session": "tsx src/scripts/test_session.ts",
    "list-channels": "tsx src/scripts/list_channels/index.ts",
    "replay-messages": "tsx src/scripts/replay_messages.ts",
    "reprocess-message": "tsx src/scripts/reprocess_message.ts",
    "test-bybit-credentials": "tsx src/scripts/test_bybit_credentials.ts",
    "test-ctrader-balance": "tsx src/scripts/test_ctrader_balance.ts",
    "test-ctrader-positions": "tsx src/scripts/test_ctrader_positions.ts",
    "ctrader-order-link-research": "tsx src/scripts/ctrader_order_position_link_research.ts",
    "ctrader-orders-today": "tsx src/scripts/ctrader_orders_today.ts",
    "test-ctrader-tp": "tsx src/scripts/test_ctrader_tp_placement.ts",
    "cancel-ctrader-order": "tsx src/scripts/cancel_ctrader_order.ts",
    "open-ctrader-trade": "tsx src/scripts/open_ctrader_trade.ts",
    "troubleshoot-trade": "tsx src/scripts/troubleshoot_trade.ts",
    "debug-ctrader-closures": "tsx src/scripts/debug_ctrader_trade_closures.ts",
    "trace-message": "tsx src/scripts/trace_message.ts",
    "query-bybit-day": "tsx src/scripts/query_bybit_day_window.ts",
    "investigate": "tsx src/investigation/cli.ts",
    "query-loggly": "tsx src/scripts/query_loggly.ts",
    "loggly-diagnose": "tsx src/scripts/loggly_diagnose.ts",
    "loggly-query-message": "tsx src/scripts/loggly_query_message.ts",
    "search-private-chats": "tsx src/scripts/search_private_chats.ts",
    "mcp:loggly": "tsx src/mcp/logglyServer.ts",
    "mcp:investigation": "tsx src/mcp/investigationServer.ts",
    "fix-trade-tps": "tsx src/scripts/fix_trade_tps.ts",
    "analyze-tp-sl": "tsx src/scripts/analyze_tp_sl_order.ts",
    "verify-parser": "tsx src/scripts/verify_parser.ts",
    "extract-trade-from-image": "tsx src/scripts/extract_trade_from_image.ts",
    "validate-symbol": "tsx src/scripts/validate_symbol.ts --",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "crypto",
    "trading",
    "bot",
    "telegram",
    "bybit"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "better-sqlite3": "^12.6.2",
    "bybit-api": "^4.4.2",
    "commander": "^7.2.0",
    "csv-parse": "^5.5.6",
    "csv-writer": "^1.6.0",
    "dayjs": "^1.11.19",
    "discord.js": "^14.14.1",
    "discord.js-selfbot-v13": "^3.7.1",
    "dotenv": "^17.2.3",
    "dukascopy-node": "^1.46.3",
    "fast-redact": "^3.5.0",
    "fs-extra": "^11.3.2",
    "input": "^1.0.1",
    "p-limit": "^7.3.0",
    "pg": "^8.11.3",
    "protobufjs": "^5.0.1",
    "telegram": "^2.26.22",
    "uuid": "^8.3.2",
    "webpack-cli": "^4.10.0",
    "winston": "^3.15.0",
    "winston-loggly-bulk": "^3.3.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/fast-redact": "^3.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^10.0.0",
    "@types/winston-loggly-bulk": "^3.0.6",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.14"
  }
}
